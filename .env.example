# ── Supabase ────────────────────────────────────────────────────────────────────
# Settings > API in your Supabase project dashboard

# Public URL — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon / public key — safe for browser (used for Realtime subscriptions + read-only queries)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role secret — NEVER expose to the browser. Used only in API routes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Resend (email) ───────────────────────────────────────────────────────────────
# Create a free account at resend.com, then Settings > API Keys > Create API Key
RESEND_API_KEY=re_your_api_key_here

# The "from" address for outgoing emails.
# For testing: use "onboarding@resend.dev" (only delivers to your own Resend account email)
# For production: use "noreply@yourdomain.com" after verifying your domain in Resend
RESEND_FROM_EMAIL=PeerVote <onboarding@resend.dev>

# ── App URL ──────────────────────────────────────────────────────────────────────
# Base URL of your deployed app — used to build voting links inside emails.
# In development: http://localhost:3000
# In production:  https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
